{
  "name": "agentic-sdlc-toolkit",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Development repository for the agentic SDLC toolkit used by OpenCode-compatible AI coding agents.",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "sdlc": "src/scripts/sdlc.mjs"
  },
  "scripts": {
    "test": "node --test test/unit/*.test.mjs test/e2e/*.test.mjs test/contracts/*.test.mjs",
    "deploy": "node bin/deploy-to-agent.mjs",
    "sdlc": "node src/scripts/sdlc.mjs",
    "build": "node bin/build-runtime.mjs",
    "validate:contracts": "node bin/validate-contracts.mjs",
    "validate:templates": "node bin/validate-templates.mjs",
    "lint:artifact": "node bin/lint-artifact.mjs",
    "validate": "npm run validate:schemas && npm run validate:policies && npm run validate:contracts && npm run validate:templates && npm test",
    "test:unit": "node --test test/unit/*.test.mjs",
    "test:e2e": "node --test test/e2e/*.test.mjs",
    "test:contracts": "node --test test/contracts/*.test.mjs",
    "validate:schemas": "node bin/validate-schemas.mjs",
    "validate:policies": "node bin/validate-policies.mjs",
    "validate:fixtures": "npm run test:contracts",
    "check:all": "npm run test:all && npm run deploy:smoke",
    "deploy:smoke": "node bin/deploy-to-agent.mjs --dest .tmp/agent --project-root .tmp/project --bundle --clean",
    "test:all": "npm run validate && npm run test:unit && npm run test:contracts && npm run test:e2e"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "ignore": "^7.0.6",
    "yaml": "^2.5.1"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  }
}
